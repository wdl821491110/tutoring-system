{
  "envId": "touring-d1g3bubk681ee89e9",
  "version": "2.0",
  "framework": {
    "name": "flask",
    "plugins": {
      "http": {
        "use": "@cloudbase/framework-plugin-http",
        "inputs": {
          "services": [
            {
              "path": "/api/",
              "charset": "utf8",
              "domain": "*",
              "debug": {
                "enable": true
              },
              "strategy": "openapi",
              "envVariables": {}
            },
            {
              "path": "/",
              "charset": "utf8",
              "domain": "*",
              "debug": {
                "enable": true
              },
              "strategy": "openapi",
              "envVariables": {}
            }
          ]
        }
      },
      "container": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "serviceName": "tutoring-system",
          "servicePath": "/",
          "containerPort": 80,
          "dockerfilePath": "Dockerfile",
          "envVariables": {
            "PORT": "80"
          }
        }
      }
    }
  },
  "cloudrun": {
    "name": "tutoring-system"
  },
  "app": {
    "serviceName": "tutoring-system",
    "installCommand": "",
    "buildCommand": "",
    "outputDir": "./"
  }
}
