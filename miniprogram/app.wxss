/* ========================================
   课消管理系统 - WeUI 原生设计体系
   全面引入 WeUI，自定义样式仅做品牌色和业务扩展
   ======================================== */

@import './package/dist-rpx-mode/style/weui.wxss';

/* ---------- CSS Variables - 微信原生色板 ---------- */
page {
  height: 100%;
  --c-primary: #07C160;
  --c-primary-dark: #06AD56;
  --c-primary-light: #E8F8EE;
  --c-primary-gradient: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  --c-bg: #F5F5F5;
  --c-card: #FFFFFF;
  --c-text: #000000;
  --c-text-secondary: #888888;
  --c-text-hint: #B2B2B2;
  --c-border: #E5E5E5;
  --c-divider: #F0F0F0;

  --c-danger: #FA5151;
  --c-danger-light: #FFF0F0;
  --c-warning: #FFC300;
  --c-warning-light: #FFF9E6;
  --c-info: #10AEFF;
  --c-info-light: #E8F6FF;
  --c-success: #07C160;
  --c-success-light: #E8F8EE;

  --r-xs: 4px;
  --r-sm: 8px;
  --r-md: 12px;
  --r-lg: 12px;
  --r-full: 9999px;

  --shadow-sm: 0 1rpx 4rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.08);
  --shadow-btn: 0 4rpx 12rpx rgba(7,193,96,0.3);

  --space-xs: 4px;
  --space-sm: 8px;
  --space-md: 12px;
  --space-lg: 16px;
  --space-xl: 24px;
  --space-xxl: 32px;

  --font-xs:   12px;
  --font-sm:   14px;
  --font-md:   17px;
  --font-lg:   20px;
  --font-xl:   24px;
  --fw-normal: 400;
  --fw-medium: 500;
  --fw-bold:   600;
  --fw-black:  700;
  --lh-tight:  1.3;
  --lh-normal: 1.5;
  --lh-loose:  1.8;

  background: var(--c-bg);
  font-family: -apple-system, BlinkMacSystemFont, Segoe UI, PingFang SC, Microsoft YaHei, sans-serif;
  font-size: 17px;
  color: var(--c-text);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* ---------- 深色模式（预留） ---------- */
@media (prefers-color-scheme: dark) {
  page {
    /* 待后续版本填充 */
  }
}

/* ---------- 页面容器 ---------- */
.page-container {
  padding: 0;
  padding-bottom: 60px;
}

/* ---------- WeUI 品牌色覆盖 ---------- */
.weui-btn_primary {
  background: var(--c-primary) !important;
}
.weui-btn_primary:active {
  opacity: 0.85;
}
.weui-dialog__btn_primary {
  color: var(--c-primary) !important;
}

/* ---------- 标签/徽章（业务扩展） ---------- */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 10px;
  border-radius: var(--r-full);
  font-size: 11px;
  font-weight: 500;
  line-height: 1.6;
}
.tag--green  { background: var(--c-success-light); color: var(--c-success); }
.tag--blue   { background: var(--c-info-light); color: var(--c-info); }
.tag--red    { background: var(--c-danger-light); color: var(--c-danger); }
.tag--gold   { background: #FFF3E0; color: #FF9800; }
.tag--gray   { background: #F0F0F0; color: var(--c-text-hint); }
.tag--xs {
  padding: 1px 6px;
  font-size: 10px;
  border-radius: 10px;
}

/* ---------- 间距工具类 ---------- */
.mt-4  { margin-top: 4px; }
.mt-8  { margin-top: 8px; }
.mt-12 { margin-top: 12px; }
.mt-16 { margin-top: 16px; }
.mt-24 { margin-top: 24px; }
.mb-8  { margin-bottom: 8px; }
.mb-12 { margin-bottom: 12px; }
.mb-16 { margin-bottom: 16px; }

/* ---------- 动画 - WeChat 原生微反馈 ---------- */
.hover-active {
  opacity: 0.6;
  transition: opacity 0.1s;
}

/* 内容入场 */
.fade-in {
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* 骨架屏 -> 内容 交叉淡入淡出 */
.skeleton-out {
  animation: skeletonOut 0.15s ease forwards;
}
@keyframes skeletonOut {
  to { opacity: 0; }
}
.content-in {
  opacity: 0;
  animation: contentIn 0.2s ease 0.05s forwards;
}
@keyframes contentIn {
  to { opacity: 1; }
}

/* ---------- 滚动条隐藏 ---------- */
::-webkit-scrollbar { display: none; }

/* ---------- 学生卡片头像 ---------- */
.student-avatar {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  color: #fff;
  font-size: 18px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ---------- 胶囊筛选 ---------- */
.filter-bar {
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
}
.filter-pill {
  display: inline-flex;
  align-items: center;
  height: 32px;
  padding: 0 14px;
  border-radius: var(--r-full);
  font-size: 14px;
  color: var(--c-text-secondary);
  background: #F0F0F0;
  white-space: nowrap;
}
.filter-pill--active {
  color: #fff;
  background: var(--c-primary);
  font-weight: 600;
  box-shadow: 0 2px 8px rgba(7,193,96,0.25);
}
.filter-action {
  display: inline-flex;
  align-items: center;
  height: 32px;
  padding: 0 14px;
  border-radius: var(--r-full);
  font-size: 14px;
  color: var(--c-primary);
  background: var(--c-primary-light);
  white-space: nowrap;
}

/* ---------- 排课操作按钮 ---------- */
.schedule-action {
  display: inline-flex;
  align-items: center;
  height: 32px;
  padding: 0 14px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 500;
}
.schedule-action--primary { background: var(--c-primary-light); color: var(--c-primary); }
.schedule-action--danger  { background: var(--c-danger-light); color: var(--c-danger); }
.schedule-action--muted   { background: #F5F5F5; color: var(--c-text-hint); }

/* ---------- 分页器 ---------- */
.pager-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 36px;
  padding: 0 16px;
  border-radius: var(--r-sm);
  font-size: 14px;
  font-weight: 500;
  background: var(--c-card);
  color: var(--c-primary);
  box-shadow: var(--shadow-sm);
}
.pager-btn--disabled {
  color: var(--c-text-hint);
  opacity: 0.5;
}

/* ---------- WeUI cell 校验错误 ---------- */
.weui-cell--error {
  border-bottom-color: var(--c-danger) !important;
  animation: form-shake 0.35s ease;
}
.weui-cell--error::after {
  content: attr(data-error);
  font-size: 12px;
  color: var(--c-danger);
  display: block;
  padding: 2px 16px 4px;
}
.weui-cell--error-text {
  color: var(--c-danger);
}
@keyframes form-shake {
  0%, 100% { transform: translateX(0); }
  15% { transform: translateX(-4px); }
  30% { transform: translateX(4px); }
  45% { transform: translateX(-3px); }
  60% { transform: translateX(3px); }
  75% { transform: translateX(-1px); }
  90% { transform: translateX(1px); }
}

/* ---------- 底部安全区 ---------- */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ---------- mp-icon 居中 ---------- */
mp-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  vertical-align: middle;
}

/* ---------- 视图切换栏 ---------- */
.view-mode-bar {
  display: flex;
  background: #F7F7F7;
  border-radius: 10px;
  padding: 4px;
  margin: 8px 8px 16px;
  gap: 4px;
}
.view-mode-item {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: 14px;
  color: var(--c-text-secondary);
  border-radius: 8px;
  font-weight: 500;
  transition: all 0.2s;
}
.view-mode-item--active {
  background: #FFFFFF;
  color: var(--c-primary);
  font-weight: 600;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}

/* ---------- 日期选择器 ---------- */
.picker-cell {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background: var(--c-card, #fff);
  border-radius: 10px;
  border: 1px solid var(--c-border, #e5e5e5);
}

/* ---------- 首字母分组标题 ---------- */
.alpha-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--c-text-hint);
  padding: 12px 8px 6px;
  letter-spacing: 1px;
}

/* ---------- 学生详情：教师信息 ---------- */
.student-info__teacher {
  font-size: 12px;
  color: var(--c-text-secondary);
  margin-top: 4px;
}

/* ---------- mp-half-screen-dialog 内容可滚动 ---------- */
.weui-half-screen-dialog__bd {
  overflow-y: auto !important;
}