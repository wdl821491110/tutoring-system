/* ========================================
   课消管理系统 - Design System v5.0
   ======================================== */

/* ---------- CSS Variables ---------- */
page {
  --c-primary: #07C160;
  --c-primary-dark: #06AD56;
  --c-primary-light: #E8F8EE;
  --c-primary-gradient: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  --c-bg: #F5F6FA;
  --c-card: #FFFFFF;
  --c-text: #1A1A1A;
  --c-text-secondary: #8E8E93;
  --c-text-hint: #C7C7CC;
  --c-border: #F0F0F0;
  --c-divider: #F5F5F5;

  --c-danger: #FA5151;
  --c-danger-light: #FFF0F0;
  --c-warning: #FFC300;
  --c-warning-light: #FFF9E6;
  --c-info: #10AEFF;
  --c-info-light: #E8F6FF;
  --c-success: #07C160;
  --c-success-light: #E8F8EE;

  --c-stat-1: #07C160;  --c-stat-1-bg: #E8F8EE;
  --c-stat-2: #10AEFF;  --c-stat-2-bg: #E8F6FF;
  --c-stat-3: #FFC300;  --c-stat-3-bg: #FFF9E6;
  --c-stat-4: #8B5CF6;  --c-stat-4-bg: #F3F0FF;
  --c-stat-5: #FA5151;  --c-stat-5-bg: #FFF0F0;

  --r-xs: 6px;
  --r-sm: 10px;
  --r-md: 14px;
  --r-lg: 20px;
  --r-full: 9999px;

  --shadow-sm: 0 1rpx 4rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.08);
  --shadow-btn: 0 4rpx 12rpx rgba(7,193,96,0.3);

  --space-xs: 4px;
  --space-sm: 8px;
  --space-md: 12px;
  --space-lg: 16px;
  --space-xl: 24px;

  background: var(--c-bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 15px;
  color: var(--c-text);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* ---------- 页面容器 ---------- */
.page-container {
  padding: var(--space-lg);
  padding-bottom: 60px;
}

/* ---------- 区块标题 ---------- */
.section-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: var(--space-md);
  display: flex;
  align-items: center;
  gap: 6px;
}
.section-title::before {
  content: '';
  width: 4px;
  height: 18px;
  background: var(--c-primary);
  border-radius: 2px;
  flex-shrink: 0;
}
.section-subtitle {
  font-size: 13px;
  color: var(--c-text-secondary);
  margin-bottom: var(--space-md);
  margin-top: -8px;
}

/* ---------- 通用卡片 ---------- */
.card {
  background: var(--c-card);
  border-radius: var(--r-md);
  padding: var(--space-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--space-md);
}
.card--hover {
  transition: transform 0.15s, box-shadow 0.15s;
}
.card--hover:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

/* ---------- 统计卡片（彩色渐变） ---------- */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: var(--space-md);
}
.stat-grid-2 {
  grid-template-columns: repeat(2, 1fr);
}

.stat-card {
  background: var(--c-card);
  border-radius: var(--r-md);
  padding: 16px 10px;
  text-align: center;
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
}
.stat-card .stat-icon {
  font-size: 26px;
  margin-bottom: 4px;
}
.stat-card .stat-num {
  font-size: 26px;
  font-weight: 700;
  line-height: 1.2;
}
.stat-card .stat-label {
  font-size: 12px;
  color: var(--c-text-secondary);
  margin-top: 2px;
}

/* ---------- 时间轴列表 ---------- */
.timeline {
  position: relative;
  padding-left: 28px;
}
.timeline::before {
  content: '';
  position: absolute;
  left: 11px;
  top: 0; bottom: 0;
  width: 2px;
  background: var(--c-border);
}
.timeline-item {
  position: relative;
  padding-bottom: 18px;
}
.timeline-item:last-child { padding-bottom: 0; }
.timeline-item::before {
  content: '';
  position: absolute;
  left: -22px;
  top: 5px;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--c-primary);
  border: 2px solid var(--c-card);
  box-shadow: 0 0 0 2px var(--c-primary-light);
  z-index: 1;
}
.timeline-dot--active::before  { background: var(--c-primary); box-shadow: 0 0 0 2px var(--c-primary-light); }
.timeline-dot--info::before    { background: var(--c-info); box-shadow: 0 0 0 2px var(--c-info-light); }
.timeline-dot--done::before    { background: var(--c-text-secondary); box-shadow: 0 0 0 2px #eee; }
.timeline-dot--danger::before  { background: var(--c-danger); box-shadow: 0 0 0 2px var(--c-danger-light); }

/* ---------- 进度条 ---------- */
.progress-bar {
  height: 8px;
  background: var(--c-border);
  border-radius: var(--r-full);
  overflow: hidden;
}
.progress-bar__fill {
  height: 100%;
  border-radius: var(--r-full);
  background: var(--c-primary-gradient);
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}
.progress-bar__fill--blue  { background: linear-gradient(135deg, #10AEFF, #0C8DE0); }
.progress-bar__fill--gold  { background: linear-gradient(135deg, #FFC300, #E6A800); }
.progress-bar__fill--purple { background: linear-gradient(135deg, #8B5CF6, #7C3AED); }

/* ---------- 标签/徽章 ---------- */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 10px;
  border-radius: var(--r-full);
  font-size: 11px;
  font-weight: 500;
  line-height: 1.6;
}
.tag--green  { background: var(--c-success-light); color: var(--c-success); }
.tag--blue   { background: var(--c-info-light); color: var(--c-info); }
.tag--gold   { background: var(--c-warning-light); color: #B8860B; }
.tag--red    { background: var(--c-danger-light); color: var(--c-danger); }
.tag--gray   { background: #F5F5F5; color: var(--c-text-secondary); }
.tag--purple { background: #F3F0FF; color: #7C3AED; }

/* ---------- 全局按钮重置 ---------- */
button {
  padding: 0;
}
button::after {
  border: none;
}

/* ---------- 按钮增强 ---------- */
.weui-btn_primary {
  background: var(--c-primary-gradient) !important;
  box-shadow: var(--shadow-btn);
  border: none !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
}
.weui-btn_primary:active {
  opacity: 0.85;
}
.weui-btn_warn {
  box-shadow: 0 2px 8px rgba(250,81,81,0.2);
}

/* ---------- 底部固定按钮区 ---------- */
.fixed-bottom {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 8px 32px;
  padding-bottom: calc(8px + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(245,246,250,0) 0%, rgba(245,246,250,0.95) 30%, var(--c-bg) 100%);
  z-index: 100;
}
/* 底部固定按钮 — 与登录按钮一致 */
.fixed-btn {
  width: 100%;
  height: 48px;
  padding: 0;
  margin: 0 auto;
  border: none;
  border-radius: var(--r-md);
  font-size: 17px;
  font-weight: 600;
  color: #fff;
  background: var(--c-primary-gradient);
  box-shadow: var(--shadow-btn);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-sizing: border-box;
}
.fixed-btn::after {
  border: none;
}
.fixed-btn:active {
  opacity: 0.85;
}

/* ---------- 搜索栏美化 ---------- */
.search-bar-wrap {
  margin-bottom: var(--space-md);
}

/* ---------- Cells 增强 ---------- */
.weui-cells {
  border-radius: var(--r-md) !important;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--space-md) !important;
}
.weui-cells__title {
  font-size: 14px !important;
  font-weight: 600 !important;
  color: var(--c-text-secondary) !important;
  padding: 12px 16px 6px !important;
}

/* ---------- Dialog 增强 ---------- */
.weui-dialog {
  border-radius: var(--r-lg) !important;
}
.weui-dialog__bd {
  padding: 0 16px !important;
}
.weui-dialog__ft .weui-dialog__btn_primary {
  color: var(--c-primary) !important;
  font-weight: 600 !important;
}

/* ---------- 空状态 ---------- */
.empty-state {
  text-align: center;
  padding: 80px 32px;
  color: var(--c-text-hint);
}
.empty-state .empty-icon {
  font-size: 56px;
  margin-bottom: 16px;
  opacity: 0.5;
}
.empty-state .empty-text {
  font-size: 15px;
  margin-top: 8px;
}
.empty-state .empty-hint {
  font-size: 13px;
  margin-top: 4px;
  opacity: 0.6;
}

/* ---------- 骨架屏 ---------- */
.skeleton {
  background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 37%, #F0F0F0 63%);
  background-size: 400% 100%;
  animation: skeleton-shine 1.4s ease infinite;
  border-radius: var(--r-xs);
}
@keyframes skeleton-shine {
  0%   { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}
.skeleton-text  { height: 14px; width: 60%; margin-bottom: 8px; }
.skeleton-title { height: 18px; width: 40%; margin-bottom: 12px; }
.skeleton-card  { height: 80px; border-radius: var(--r-md); margin-bottom: 10px; }
.skeleton-avatar { width: 44px; height: 44px; border-radius: 50%; }
.skeleton-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  background: var(--c-card);
  border-radius: var(--r-md);
  margin-bottom: 8px;
  box-shadow: var(--shadow-sm);
}
.skeleton-row__body { flex: 1; }
.skeleton-row__body .skeleton-text { width: 80%; }
.skeleton-row__body .skeleton-text:last-child { width: 50%; height: 12px; }

/* ---------- 通用工具类 ---------- */
.text-gray    { color: var(--c-text-secondary); }
.text-sm      { font-size: 13px; }
.text-xs      { font-size: 12px; }
.text-green   { color: var(--c-success); }
.text-red     { color: var(--c-danger); }
.text-orange  { color: var(--c-warning); }
.text-blue    { color: var(--c-info); }
.text-purple  { color: #8B5CF6; }
.fw-bold      { font-weight: 600; }
.mt-4  { margin-top: 4px; }
.mt-8  { margin-top: 8px; }
.mt-12 { margin-top: 12px; }
.mt-16 { margin-top: 16px; }
.mt-24 { margin-top: 24px; }
.mb-8  { margin-bottom: 8px; }
.mb-12 { margin-bottom: 12px; }
.mb-16 { margin-bottom: 16px; }

/* ---------- 动画 ---------- */
.fade-in {
  animation: fadeIn 0.3s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
.slide-up {
  animation: slideUp 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
.stagger-item {
  opacity: 0;
  animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

/* ---------- 滚动条隐藏 ---------- */
::-webkit-scrollbar { display: none; }

/* ---------- 学生卡片头像 ---------- */
.student-avatar {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  color: #fff;
  font-size: 18px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ---------- 胶囊筛选 ---------- */
.filter-bar {
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
}
.filter-pill {
  display: inline-flex;
  align-items: center;
  height: 32px;
  padding: 0 14px;
  border-radius: var(--r-full);
  font-size: 13px;
  color: var(--c-text-secondary);
  background: #F0F0F0;
  white-space: nowrap;
}
.filter-pill--active {
  color: #fff;
  background: var(--c-primary-gradient);
  font-weight: 600;
  box-shadow: 0 2px 8px rgba(7,193,96,0.25);
}
.filter-action {
  display: inline-flex;
  align-items: center;
  height: 32px;
  padding: 0 14px;
  border-radius: var(--r-full);
  font-size: 13px;
  color: var(--c-primary);
  background: var(--c-primary-light);
  white-space: nowrap;
}

/* ---------- 排课操作按钮 ---------- */
.schedule-action {
  display: inline-flex;
  align-items: center;
  height: 28px;
  padding: 0 12px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 500;
}
.schedule-action--primary { background: var(--c-primary-light); color: var(--c-primary); }
.schedule-action--danger  { background: var(--c-danger-light); color: var(--c-danger); }
.schedule-action--muted   { background: #F5F5F5; color: var(--c-text-hint); }

/* ---------- 日期输入 ---------- */
.date-input-wrap {
  flex: 1;
  background: var(--c-card);
  border-radius: var(--r-sm);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}
.date-input-wrap input {
  width: 100%;
  height: 40px;
  padding: 0 12px;
  font-size: 14px;
  color: var(--c-text);
}

/* ---------- 分页器 ---------- */
.pager-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 36px;
  padding: 0 16px;
  border-radius: var(--r-sm);
  font-size: 14px;
  font-weight: 500;
  background: var(--c-card);
  color: var(--c-primary);
  box-shadow: var(--shadow-sm);
}
.pager-btn--disabled {
  color: var(--c-text-hint);
  opacity: 0.5;
}

/* ---------- 自定义搜索栏 ---------- */
.custom-search {
  display: flex;
  align-items: center;
  height: 44px;
  background: var(--c-card);
  border-radius: 22px;
  padding: 0 16px;
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--space-md);
}
.custom-search-icon {
  font-size: 16px;
  margin-right: 8px;
  opacity: 0.4;
  flex-shrink: 0;
}
.custom-search-input {
  flex: 1;
  height: 100%;
  font-size: 15px;
  color: var(--c-text);
}
.custom-search-clear {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #E5E5E5;
  color: #999;
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8px;
  flex-shrink: 0;
}

/* ---------- 自定义覆盖层弹窗 ---------- */
.overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.overlay-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
}
.overlay-sheet {
  position: relative;
  width: 88vw;
  max-height: 80vh;
  background: var(--c-card);
  border-radius: var(--r-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.overlay-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 20px 12px;
  border-bottom: 1px solid var(--c-divider);
}
.overlay-title {
  font-size: 17px;
  font-weight: 700;
  color: var(--c-text);
}
.overlay-close {
  font-size: 18px;
  color: var(--c-text-hint);
  padding: 4px;
}
.overlay-body {
  padding: 8px 20px;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.overlay-footer {
  display: flex;
  gap: 12px;
  padding: 14px 20px;
  padding-bottom: calc(14px + env(safe-area-inset-bottom));
  border-top: 1px solid var(--c-divider);
}
.overlay-btn {
  flex: 1;
  height: 44px;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 600;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.overlay-btn::after { border: none; }
.overlay-btn--cancel {
  background: #F5F5F5;
  color: var(--c-text-secondary);
}
.overlay-btn--confirm {
  background: var(--c-primary-gradient);
  color: #fff;
  box-shadow: var(--shadow-btn);
}
.overlay-btn--confirm:active { opacity: 0.85; }

/* ---------- 表单行 ---------- */
.form-row {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid var(--c-divider);
}
.form-row:last-child { border-bottom: none; }
.form-label {
  font-size: 15px;
  color: var(--c-text-secondary);
  width: 56px;
  flex-shrink: 0;
}
.form-label--wide { width: 72px; }
.form-input {
  flex: 1;
  height: 40px;
  font-size: 15px;
  color: var(--c-text);
  text-align: right;
}
.form-picker-val {
  height: 40px;
  line-height: 40px;
  font-size: 15px;
  text-align: right;
  color: #C7C7CC;
}
.form-textarea {
  flex: 1;
  min-height: 80px;
  font-size: 15px;
  color: var(--c-text);
  padding: 4px 0;
}

/* ---------- 响应式安全区 ---------- */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
