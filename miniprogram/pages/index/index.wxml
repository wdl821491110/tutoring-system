<view class="page-container">
  <!-- 骨架屏 -->
  <view wx:if="{{loading}}" class="fade-in">
    <view class="skeleton skeleton-dashboard"></view>
  </view>

  <!-- 内容区 -->
  <view wx:else class="fade-in">

    <!-- 统计卡片 — 两两横向 -->
    <view class="stat-cards">
      <view class="stat-row">
        <view class="stat-card" hover-class="stat-card--hover" bindtap="goPage" data-url="/pages/students/students">
          <text class="stat-card__num">{{stats.total_students||0}}</text>
          <text class="stat-card__label">在籍学生</text>
        </view>
        <view class="stat-card" hover-class="stat-card--hover" bindtap="goPage" data-url="/pages/schedules/schedules">
          <text class="stat-card__num">{{stats.today_count||0}}</text>
          <text class="stat-card__label">今日排课</text>
        </view>
      </view>
      <view class="stat-row">
        <view class="stat-card" hover-class="stat-card--hover" bindtap="goPage" data-url="/pages/records/records">
          <text class="stat-card__num">{{stats.today_consumed||0}}</text>
          <text class="stat-card__label">今日消课</text>
        </view>
        <view class="stat-card" hover-class="stat-card--hover" bindtap="goPage" data-url="/pages/records/records">
          <text class="stat-card__num">{{stats.total_remaining||0}}</text>
          <text class="stat-card__label">剩余总课时</text>
        </view>
      </view>
    </view>

    <!-- 近30天消耗排行 — 进度条 + 百分比 -->
    <view wx:if="{{stats.course_ranking && stats.course_ranking.length>0}}" class="weui-cells__title">近30天消耗排行</view>
    <view wx:if="{{stats.course_ranking && stats.course_ranking.length>0}}" class="rank-list">
      <view wx:for="{{stats.course_ranking}}" wx:key="name" wx:for-index="idx" class="rank-item">
        <view class="rank-cell__hd">
          <view class="rank-cell__left">
            <text class="rank-cell__idx">{{idx+1}}</text>
            <text class="rank-cell__title">{{item.name}}</text>
            <text class="rank-cell__sub" wx:if="{{item.subject}}">{{item.subject}}</text>
          </view>
          <text class="rank-cell__val">{{item.percent||0}}%</text>
        </view>
        <view class="weui-progress">
          <view class="weui-progress__bar">
            <view class="weui-progress__inner-bar {{idx===0?'weui-progress__inner-bar--active':''}}"
              style="width:{{item.percent||0}}%;">
            </view>
          </view>
        </view>
        <view class="rank-cell__meta">
          <text>已消耗 {{item.total_hours}} 课时</text>
          <text wx:if="{{item.enrolled_hours}}"> / 共 {{item.enrolled_hours}} 课时</text>
          <text wx:if="{{item.teacher_name}}"> · {{item.teacher_name}}</text>
        </view>
      </view>
    </view>

  </view>
</view>
