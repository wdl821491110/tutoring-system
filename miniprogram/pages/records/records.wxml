<view class="page-container fade-in">
  <!-- 日期范围 -->
  <view style="display:flex;gap:8px;align-items:center;margin-bottom:16px;">
    <view class="date-input-wrap">
      <input type="date" value="{{dateFrom}}" bindchange="onDateFrom" placeholder="开始日期"/>
    </view>
    <text style="color:#8E8E93;font-size:14px;">至</text>
    <view class="date-input-wrap">
      <input type="date" value="{{dateTo}}" bindchange="onDateTo" placeholder="结束日期"/>
    </view>
  </view>

  <!-- 骨架屏 -->
  <view wx:if="{{loading}}">
    <view class="skeleton-row" wx:for="{{[0,0,0,0,0]}}" wx:key="*this">
      <view class="skeleton-row__body">
        <view class="skeleton-text"></view>
        <view class="skeleton-text"></view>
      </view>
    </view>
  </view>

  <!-- 课时记录列表 -->
  <block wx:else>
  <view wx:if="{{list.length>0}}">
    <view class="section-title">课时记录 · {{total}}条</view>
    <view
      class="card slide-up"
      wx:for="{{list}}"
      wx:key="id"
      style="padding:14px 16px;margin-bottom:8px;"
    >
      <view style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;">
        <text style="font-size:16px;font-weight:600;flex:1;">{{item.student_name}} · {{item.course_name}}</text>
        <text class="tag {{item.attendance==='present'?'tag--green':'tag--red'}}">
          {{item.attendance==='present'?'出勤 ✓':'缺勤 ✗'}}
        </text>
      </view>
      <view class="text-sm text-gray">
        {{item.record_date}} · {{item.subject}} · {{item.teacher_name||'-'}}
      </view>
      <view style="display:flex;justify-content:space-between;align-items:center;margin-top:8px;">
        <view style="display:flex;align-items:center;gap:8px;">
          <text style="font-size:14px;font-weight:600;color:var(--c-primary);">{{item.hours_consumed}}课时</text>
          <text class="tag tag--gray" style="font-size:10px;">剩{{item.remaining_after}}课时</text>
        </view>
        <view style="display:flex;align-items:center;gap:10px;">
          <text style="font-size:13px;color:var(--c-text-secondary);" bindtap="showNotes" data-rid="{{item.id}}">📝 {{item.note_count||0}}</text>
          <text wx:if="{{isAdmin}}" style="font-size:13px;color:var(--c-danger);" bindtap="undoRecord" data-rid="{{item.id}}">撤销</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 分页 -->
  <view wx:if="{{totalPages>1}}" style="display:flex;justify-content:center;align-items:center;gap:20px;padding:20px 0 32px;">
    <view class="pager-btn {{page<=1?'pager-btn--disabled':''}}" bindtap="prevPage">‹ 上一页</view>
    <text style="font-size:14px;color:var(--c-text-secondary);font-weight:500;">{{page}} / {{totalPages}}</text>
    <view class="pager-btn {{page>=totalPages?'pager-btn--disabled':''}}" bindtap="nextPage">下一页 ›</view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{list.length===0}}" class="empty-state">
    <view class="empty-icon">✅</view>
    <view class="empty-text">暂无消课记录</view>
    <view class="empty-hint">去「排课」页面签到，或直接新增消课记录</view>
  </view>

  <!-- 自定义新增表单弹窗 -->
  <view class="overlay" wx:if="{{showForm}}" catchtouchmove="noop">
    <view class="overlay-mask" bindtap="closeForm"></view>
    <view class="overlay-sheet slide-up">
      <view class="overlay-header">
        <text class="overlay-title">新增消课记录</text>
        <text class="overlay-close" bindtap="closeForm">✕</text>
      </view>
      <view class="overlay-body">
        <view class="form-row">
          <text class="form-label">学生</text>
          <picker style="flex:1;" range="{{studentNames}}" value="{{form.studentIdx}}" bindchange="onStudentChange">
            <view class="form-picker-val">{{studentNames[form.studentIdx]||'请选择'}}</view>
          </picker>
        </view>
        <view class="form-row">
          <text class="form-label">课程</text>
          <picker style="flex:1;" range="{{courseNames}}" value="{{form.courseIdx}}" bindchange="onCourseChange">
            <view class="form-picker-val">{{courseNames[form.courseIdx]||'请选择'}}</view>
          </picker>
        </view>
        <view class="form-row">
          <text class="form-label">日期</text>
          <input class="form-input" type="date" value="{{form.record_date}}" data-field="record_date" bindinput="onFieldChange"/>
        </view>
        <view class="form-row">
          <text class="form-label">课时</text>
          <input class="form-input" type="number" value="{{form.hours_consumed}}" data-field="hours_consumed" bindinput="onFieldChange"/>
        </view>
        <view class="form-row">
          <text class="form-label">出勤</text>
          <view style="display:flex;gap:20px;flex:1;justify-content:flex-end;">
            <label style="display:flex;align-items:center;gap:4px;">
              <radio value="present" checked="{{form.attendance==='present'}}" bindchange="onFieldChange" data-field="attendance" color="#07C160"/>出勤
            </label>
            <label style="display:flex;align-items:center;gap:4px;">
              <radio value="absent" checked="{{form.attendance==='absent'}}" bindchange="onFieldChange" data-field="attendance" color="#FA5151"/>缺勤
            </label>
          </view>
        </view>
        <view class="form-row" style="align-items:flex-start;">
          <text class="form-label" style="padding-top:8px;">备注</text>
          <textarea class="form-textarea" placeholder="备注" value="{{form.notes}}" data-field="notes" bindinput="onFieldChange"/>
        </view>
      </view>
      <view class="overlay-footer">
        <button class="overlay-btn overlay-btn--cancel" bindtap="closeForm">取消</button>
        <button class="overlay-btn overlay-btn--confirm" bindtap="submitRecord">确定消课</button>
      </view>
    </view>
  </view>

  <!-- 自定义备注弹窗 -->
  <view class="overlay" wx:if="{{showNotes}}" catchtouchmove="noop">
    <view class="overlay-mask" bindtap="closeNotes"></view>
    <view class="overlay-sheet slide-up" style="max-height:60vh;display:flex;flex-direction:column;">
      <view class="overlay-header">
        <text class="overlay-title">备注</text>
        <text class="overlay-close" bindtap="closeNotes">✕</text>
      </view>
      <view class="overlay-body" style="flex:1;overflow-y:auto;">
        <view wx:if="{{notes.length===0}}" style="text-align:center;padding:30px;color:#C7C7CC;font-size:14px;">暂无备注</view>
        <view wx:for="{{notes}}" wx:key="id" style="padding:12px 0;border-bottom:1px solid var(--c-divider);">
          <view style="font-size:12px;color:#C7C7CC;margin-bottom:4px;">{{item.created_at}} · {{item.created_by||''}}</view>
          <view style="font-size:15px;line-height:1.6;">{{item.content}}</view>
        </view>
        <view style="margin-top:14px;">
          <textarea style="width:100%;min-height:64px;border:1px solid var(--c-border);border-radius:10px;padding:10px;font-size:14px;box-sizing:border-box;" placeholder="输入备注内容" value="{{newNoteContent}}" bindinput="onNoteInput"/>
        </view>
      </view>
      <view class="overlay-footer">
        <button class="overlay-btn overlay-btn--cancel" bindtap="closeNotes">关闭</button>
        <button class="overlay-btn overlay-btn--confirm" bindtap="addNote">添加</button>
      </view>
    </view>
  </view>

  <view class="fixed-bottom">
    <button class="fixed-btn" bindtap="showAdd">＋ 新增消课记录</button>
  </view>
  </block>
</view>
