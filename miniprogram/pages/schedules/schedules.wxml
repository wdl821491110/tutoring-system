<view class="page-container">
  <!-- ====== 固定顶部区域 ====== -->
  <view class="sticky-top">
    <!-- 日期筛选 + 批量签到 — 同行左右 -->
    <view class="top-bar">
      <view class="top-bar__date">
        <view class="weui-cell">
          <view class="weui-cell__hd"><view class="weui-label">日期</view></view>
          <view class="weui-cell__bd">
            <picker mode="date" value="{{dateFilter}}" bindchange="onDateChange">
              <view>{{dateFilter||'选择日期'}}</view>
            </picker>
          </view>
          <view class="weui-cell__ft">
            <view class="filter-today-btn" hover-class="hover-active" bindtap="filterToday">今天</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 标题栏 — 按钮在上，标题在下 -->
    <view wx:if="{{list.length>=0}}" class="schedule-header">
      <view wx:if="{{isAdmin}}" class="schedule-header__actions">
        <text wx:if="{{!batchMode}}" class="schedule-header__card schedule-header__batch-btn" bindtap="toggleBatchMode">批量签到</text>
        <block wx:else>
          <text class="schedule-header__card schedule-header__batch-btn" bindtap="selectAll">全选</text>
          <text class="schedule-header__card schedule-header__batch-btn schedule-header__batch-btn--green" bindtap="batchCheckin">签到({{checkedIds.length}})</text>
          <text class="schedule-header__card schedule-header__batch-btn schedule-header__batch-btn--gray" bindtap="toggleBatchMode">取消</text>
        </block>
        <button class="schedule-header__card schedule-header__add-btn" bindtap="showAdd"> 新增排课</button>
      </view>
    </view>

    <!-- 状态胶囊筛选 — 两端对齐 -->
    <view class="filter-status">
      <text class="filter-pill {{statusIdx===0?'filter-pill--active':''}}" hover-class="{{statusIdx===0?'':'hover-active'}}" bindtap="onStatusChange" data-idx="0">全部</text>
      <text class="filter-pill {{statusIdx===1?'filter-pill--active':''}}" hover-class="{{statusIdx===1?'':'hover-active'}}" bindtap="onStatusChange" data-idx="1">待上课</text>
      <text class="filter-pill {{statusIdx===2?'filter-pill--active':''}}" hover-class="{{statusIdx===2?'':'hover-active'}}" bindtap="onStatusChange" data-idx="2">已完成</text>
      <text class="filter-pill {{statusIdx===3?'filter-pill--active':''}}" hover-class="{{statusIdx===3?'':'hover-active'}}" bindtap="onStatusChange" data-idx="3">已取消</text>
    </view>
    <view class="schedule-header__card">
      <text class="schedule-header__title">排课列表 · {{list.length}}节</text>
    </view>
  </view>

  <!-- ====== 骨架屏 ====== -->
  <view wx:if="{{loading}}" class="fade-in" style="flex:1;overflow-y:auto;padding:0 16px;">
    <view class="skeleton-row" wx:for="{{[0,0,0,0,0]}}" wx:key="*this">
      <view class="skeleton-row__body">
        <view class="skeleton-text"></view>
        <view class="skeleton-text"></view>
      </view>
    </view>
  </view>

  <!-- ====== 可滚动排课列表 ====== -->
  <scroll-view
    wx:if="{{!loading && list.length>0}}"
    class="scroll-body"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
  >
    <view class="schedule-list">
      <view wx:for="{{list}}" wx:key="id" class="weui-cell">
          <!-- 批量模式复选框 --><view wx:if="{{batchMode && item.status==='scheduled'}}" class="batch-checkbox" bindtap="onCheckToggle" data-id="{{item.id}}"><text>{{checkedIds.indexOf(item.id)>-1?'✓':''}}</text></view>
          <view class="weui-cell__bd">
            <view class="schedule-cell__hd">
              <view class="schedule-cell__left">
                <text class="schedule-cell__title">{{item.student_name}} · {{item.course_name}}</text>
                <text class="schedule-cell__hours">{{item.hours}}课时</text>
              </view>
              <text class="tag {{item.status==='cancelled'?'tag--gray':'tag--green'}}">
                {{item.status==='completed'?'已完成':item.status==='cancelled'?'已取消':'待上课'}}
              </text>
            </view>
            <view class="schedule-cell__meta">{{item.schedule_date}} {{item.start_time}}-{{item.end_time}}<text wx:if="{{item.teacher_name}}"> · {{item.teacher_name}}</text></view>
            <view wx:if="{{item.status==='scheduled' && !batchMode}}" class="schedule-actions">
              <text wx:if="{{isAdmin||isTeacher}}" class="schedule-action schedule-action--primary" hover-class="hover-active" bindtap="doCheckin" data-id="{{item.id}}">签到消课</text>
              <text wx:if="{{isAdmin}}" class="schedule-action schedule-action--warn" hover-class="hover-active" bindtap="showEdit" data-schedule="{{item}}">编辑</text>
              <text wx:if="{{isAdmin||isTeacher}}" class="schedule-action schedule-action--danger" hover-class="hover-active" bindtap="doCancel" data-id="{{item.id}}">取消</text>
              <text wx:if="{{isAdmin}}" class="schedule-action schedule-action--muted" hover-class="hover-active" bindtap="deleteSchedule" data-schedule="{{item}}">删除</text>
            </view>
          </view>
        </view>
      </view>
  </scroll-view>

  <!-- ====== 空状态 ====== --
  <view wx:if="{{!loading && list.length===0}}" style="flex:1;">
    <view class="empty-state">
      <view class="empty-icon">
        <mp-icon type="info" size="48" color="#B2B2B2"></mp-icon>
      </view>
      <view class="empty-text">暂无排课数据</view>
      <view class="empty-hint">{{dateFilter?'该日期暂未排课':'点击下方按钮开始排课'}}</view>
    </view>
    <view wx:if="{{isAdmin}}" class="fixed-bottom">
      <button class="weui-btn weui-btn_primary" bindtap="showAdd"> 新增排课</button>
    </view>
  </view>
  >

  <!-- 新增/编辑排课表单 — form-sheet -->
  <form-sheet
    show="{{showForm}}"
    title="{{editingId?'编辑排课':'新增排课'}}"
    confirmDisabled="{{!formValid}}"
    submitting="{{submitting}}"
    bind:cancel="closeForm"
    bind:confirm="submitSchedule"
  >
    <view class="weui-cells weui-cells_form">
      <view class="weui-cell weui-cell_access {{errors.student?'weui-cell--error':''}}" data-error="请选择学生">
        <view class="weui-cell__hd"><view class="weui-label">学生</view></view>
        <view class="weui-cell__bd">
          <picker range="{{studentNames}}" value="{{form.studentIdx}}" bindchange="onStudentChange">
            <view class="{{!studentNames[form.studentIdx]&&errors.student?'weui-cell--error-text':''}}">{{studentNames[form.studentIdx]||'请选择'}}</view>
          </picker>
        </view>
        <view class="weui-cell__ft weui-cell__ft_in-access"></view>
      </view>
      <view class="weui-cell weui-cell_access {{errors.course?'weui-cell--error':''}}" data-error="请选择课程">
        <view class="weui-cell__hd"><view class="weui-label">课程</view></view>
        <view class="weui-cell__bd">
          <picker range="{{courseNames}}" value="{{form.courseIdx}}" bindchange="onCourseChange">
            <view>{{courseNames[form.courseIdx]||'请选择'}}</view>
          </picker>
        </view>
        <view class="weui-cell__ft weui-cell__ft_in-access"></view>
      </view>
      <view class="weui-cell weui-cell_access">
        <view class="weui-cell__hd"><view class="weui-label">日期</view></view>
        <view class="weui-cell__bd">
          <picker mode="date" value="{{form.schedule_date}}" bindchange="onFormChange" data-field="schedule_date">
            <view>{{form.schedule_date||'选择日期'}}{{form.schedule_weekday?' '+form.schedule_weekday:''}}</view>
          </picker>
        </view>
        <view class="weui-cell__ft weui-cell__ft_in-access"></view>
      </view>
      <view class="weui-cell weui-cell_access">
        <view class="weui-cell__hd"><view class="weui-label">开始</view></view>
        <view class="weui-cell__bd">
          <picker mode="time" value="{{form.start_time}}" bindchange="onFormChange" data-field="start_time">
            <view>{{form.start_time||'选择时间'}}</view>
          </picker>
        </view>
        <view class="weui-cell__ft weui-cell__ft_in-access"></view>
      </view>
      <view class="weui-cell weui-cell_access">
        <view class="weui-cell__hd"><view class="weui-label">结束</view></view>
        <view class="weui-cell__bd">
          <picker mode="time" value="{{form.end_time}}" bindchange="onFormChange" data-field="end_time">
            <view>{{form.end_time||'选择时间'}}</view>
          </picker>
        </view>
        <view class="weui-cell__ft weui-cell__ft_in-access"></view>
      </view>
      <view class="weui-cell">
        <view class="weui-cell__hd"><view class="weui-label">课时</view></view>
        <view class="weui-cell__bd">
          <input class="weui-input" type="number" placeholder="课时数" value="{{form.hours}}" data-field="hours" bindinput="onFieldInput"/>
        </view>
      </view>
      <view class="weui-cell">
        <view class="weui-cell__hd"><view class="weui-label">备注</view></view>
        <view class="weui-cell__bd">
          <textarea placeholder="备注信息" value="{{form.notes}}" data-field="notes" bindinput="onFieldInput" style="width:100%;min-height:60px;font-size:15px;padding:4px 0;"/>
        </view>
      </view>
    </view>
  </form-sheet>
</view>
