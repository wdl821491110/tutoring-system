/* ========================================
   学生管理 — WeUI Panel 图文组合列表
   ======================================== */

/* ---------- 页面 Flex 布局：固定顶部 + 滚动列表 ---------- */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding-bottom: 0;
}

/* ---------- 固定顶部 ---------- */
.sticky-top {
  flex-shrink: 0;
}

/* ---------- 标题栏 — 左右对称卡片 ---------- */
.student-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 16px 12px;
  gap: 12px;
}
.student-header__card {
  background: #F7F8FA;
  border-radius: 16px;
  padding: 10px 16px;
  display: flex;
  align-items: center;
}
.student-header__title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}
.student-header__add-btn {
  flex-shrink: 0;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: 16px !important;
  font-weight: 500 !important;
  line-height: 1 !important;
  color: #fff !important;
  background: var(--c-primary) !important;
  border: none !important;
  margin: 0 !important;
  padding-left: 14px !important;
  padding-right: 14px !important;
}
.student-header__add-btn::after {
  border: none;
}

/* ---------- 列表背景框 — 圆角卡片 ---------- */
.scroll-body {
  flex: 1;
  overflow: hidden;
}

/* ---------- 头像 — 灰度圆角 ---------- */
.student-avatar {
  width: 60px;
  height: 60px;
  border-radius: 8px;
  background: #E8E8E8;
  color: #888;
  font-size: 20px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16px;
}

/* ---------- 性别 — 中性文本 ---------- */
.student-gender {
  font-size: 14px;
  color: var(--c-text-secondary);
  font-weight: 400;
  margin-left: 4px;
}

/* ---------- 年级/学校 — 内联 ---------- */
.student-grade {
  font-size: 13px;
  color: var(--c-text-hint);
  margin-left: 8px;
}
.student-school {
  font-size: 13px;
  color: var(--c-text-hint);
  margin-left: 4px;
}

/* ---------- 课程标签 — 灰度 ---------- */
.student-courses {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 8px;
}
.student-course-tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 10px;
  border-radius: 4px;
  font-size: 12px;
  color: #666;
  background: #F0F0F0;
  line-height: 1.8;
}

/* ---------- mp-slideview 按钮 ---------- */
.slide-edit { background: #888 !important; }
.slide-delete { background: #999 !important; }

/* ---------- 列表卡片统一圆角 ---------- */
.student-list {
  padding: 12px 0;
  margin: 0 16px 16px;
}

.student-list mp-slideview {
  display: block;
  margin-bottom: 12px;
}

.student-list mp-slideview:last-child {
  margin-bottom: 0;
}
