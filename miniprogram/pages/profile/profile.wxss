/* ========================================
   个人中心 — WeUI 风格
   ======================================== */

/* ---------- 页面 Flex 布局：固定顶部 + 滚动列表 ---------- */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding-bottom: 0;
}
.sticky-top {
  flex-shrink: 0;
}
.scroll-body {
  flex: 1;
  overflow: hidden;
}

/* 用户头像区 — 圆角卡片 */
.profile-hero {
  text-align: center;
  padding: 32px 16px 24px;
  background: #fff;
  border-radius: 16px;
  margin: 8px 8px 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}
.profile-avatar-wrap {
  position: relative;
  width: 64px;
  height: 64px;
  margin: 0 auto 12px;
}
.profile-avatar {
  width: 64px;
  height: 64px;
  border-radius: 8px;
  background: #E8E8E8;
  color: #888;
  font-size: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.profile-avatar-img {
  width: 64px;
  height: 64px;
  border-radius: 8px;
}
.profile-avatar-badge {
  position: absolute;
  right: -4px;
  bottom: -4px;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #fff;
  border: 1px solid #E5E5E5;
  display: flex;
  align-items: center;
  justify-content: center;
}
.profile-name {
  font-size: 20px;
  color: var(--c-text);
}

/* ---------- 面板卡片圆角统一 ---------- */
.profile-panel {
  padding: 0 8px 8px;
}

.profile-panel .weui-cells {
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

/* 权限状态 — 灰度化 */
.text-green, .text-red {
  color: var(--c-text-secondary) !important;
  font-size: 14px;
}

/* 底部 */
.profile-footer {
  margin-top: 32px;
  text-align: center;
}
.logout-wrap {
  width: 200px;
  margin: 0 auto;
}
.profile-version {
  font-size: 12px;
  color: var(--c-text-hint);
  margin-top: 16px;
}

/* 骨架屏占位 */
.skeleton-hero  { height: 120px; border-radius: 14px; margin-bottom: 16px; }
.skeleton-block { height: 80px; border-radius: 14px; margin-bottom: 16px; }
.skeleton-panel { height: 100px; border-radius: 14px; margin-bottom: 16px; }

/* 角色标签间距 */
.profile-hero .tag { margin-top: 6px; }
