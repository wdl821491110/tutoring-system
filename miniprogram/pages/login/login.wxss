/* ========================================
   登录页 — WeUI 风格
   ======================================== */

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: var(--c-bg);
  padding: 0 24px;
}

/* Hero 区 */
.login-hero {
  text-align: center;
  margin-top: 80px;
  margin-bottom: 40px;
}

.login-logo-circle {
  width: 80px;
  height: 80px;
  margin: 0 auto 20px;
  border-radius: 50%;
  background: var(--c-primary);
  color: #fff;
  font-size: 36px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-title {
  font-size: 24px;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 6px;
}

.login-subtitle {
  font-size: 14px;
  color: var(--c-text-secondary);
}

/* WeUI 表单覆盖 */
.login-page .weui-cells_form {
  width: 84%;
  border-radius: 14px;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.login-page .weui-cell {
  padding: 14px 16px;
}
.login-page .weui-cell__hd {
  margin-right: 15px;
}
.login-page .weui-label {
  width: auto !important;
  min-width: 0;
}

/* 清除按钮 */
.login-input-clear {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #D8D8D8;
  display: flex;
  align-items: center;
  justify-content: center;
}
.login-input-clear text {
  font-size: 11px;
  color: #fff;
  line-height: 1;
}
.login-input-clear:active {
  opacity: 0.8;
}

/* 密码切换按钮 */
.login-input-toggle {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.5;
}
.login-input-toggle:active {
  opacity: 0.8;
}
.login-input-toggle text {
  font-size: 16px;
  line-height: 1;
}

/* 登录按钮 */
.login-btn-wrap {
  width: 86%;
  margin-top: 28px;
}

/* 按钮禁用态 */
.login-btn-wrap .weui-btn[disabled] {
  background: #A8E6C1 !important;
  color: rgba(255,255,255,0.7);
}

/* 底部 */
.login-footer {
  margin-top: 24px;
  font-size: 12px;
  text-align: center;
}

.login-privacy-agree {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.login-checkbox {
  width: 18px;
  height: 18px;
  border: 2px solid var(--c-border);
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.login-checkbox--checked {
  background: var(--c-primary);
  border-color: var(--c-primary);
}

.login-footer-hint {
  color: var(--c-text-hint);
}

.login-privacy-link {
  color: var(--c-primary);
  margin-left: -2px;
}
