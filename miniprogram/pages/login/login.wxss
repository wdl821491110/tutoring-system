/* ========================================
   登录页 — 课消管理系统
   ======================================== */

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: var(--c-bg);
  padding: 0 32px;
}

/* Hero 区 */
.login-hero {
  text-align: center;
  margin-top: 80px;
  margin-bottom: 40px;
}

.login-logo-circle {
  width: 80px;
  height: 80px;
  margin: 0 auto 20px;
  border-radius: 24px;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  box-shadow: 0 8px 24px rgba(7,193,96,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-logo-icon {
  font-size: 36px;
}

.login-title {
  font-size: 24px;
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 6px;
}

.login-subtitle {
  font-size: 14px;
  color: var(--c-text-secondary);
}

/* 输入卡片 */
.login-form-card {
  width: 100%;
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

.login-input-group {
  display: flex;
  align-items: center;
  padding: 0 16px;
  height: 52px;
}

.login-input-icon {
  font-size: 18px;
  margin-right: 12px;
  flex-shrink: 0;
}

.login-input {
  flex: 1;
  height: 100%;
  font-size: 16px;
  color: var(--c-text);
}

.login-input-divider {
  height: 1px;
  background: var(--c-divider);
  margin: 0 16px;
}

/* 登录按钮 */
.login-btn-wrap {
  width: 100%;
  margin-top: 28px;
}

.login-btn {
  width: 100%;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  font-weight: 600;
  color: #fff;
  background: var(--c-primary-gradient);
  border: none;
  border-radius: var(--r-md);
  box-shadow: var(--shadow-btn);
  padding: 0;
  line-height: 1;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  opacity: 0.85;
}

/* 底部 */
.login-footer {
  margin-top: 24px;
  font-size: 12px;
  text-align: center;
}

.login-privacy-link {
  color: var(--c-primary);
  margin-left: 2px;
}
